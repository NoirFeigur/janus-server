# Secrets and connection strings only. Behavior defaults live in src/config.py.

# Deployment environment. "local" (default) skips the production config fail-fast
# checks. Any non-local value (e.g. "staging" / "production") makes startup REQUIRE:
# a JWT signing key, debug=False, no wildcard CORS, and trusted_proxy_count >= 1 —
# the process refuses to boot otherwise (see src/config.validate_runtime).
JANUS_ENVIRONMENT=local

JANUS_DATABASE_URL=postgresql+asyncpg://janus:janus@localhost:5432/janus
JANUS_REDIS_URL=redis://localhost:6379/0
JANUS_REDIS_ARQ_URL=redis://localhost:6379/1

# Platform JWT signing key for local username/password login (RS256, PKCS8 PEM).
# Only the token issuer (login) needs the private key; replicas verify with the
# derived public key. Escaped newlines (\n) are accepted on a single line.
# REQUIRED outside local (startup fails without it).
JANUS_PLATFORM_JWT_PRIVATE_KEY=

# Reverse-proxy trust. Replicas run behind nginx, so request.client.host is the
# proxy IP; this is the number of trusted proxy hops used to recover the real
# client IP from X-Forwarded-For for per-IP login throttling. 0 (default) trusts
# nothing (direct dev). Set to 1 behind a single nginx — REQUIRED (>=1) outside local.
JANUS_TRUSTED_PROXY_COUNT=0

# Allowed CORS origins (comma/JSON list). Empty = same-origin only (no CORS).
# A wildcard "*" is REJECTED outside local (it pairs with credentialed requests
# into a cross-origin credential-theft hole) — pin explicit frontend origins.
# JANUS_CORS_ALLOW_ORIGINS=["https://admin.example.com"]

# Object storage (MinIO / S3-compatible, private bucket). Endpoint/bucket are
# deployment-specific connection info; access/secret are credentials. Reads use
# short-lived presigned URLs; the DB only stores bucket-relative object keys.
JANUS_OSS_ENDPOINT_URL=http://localhost:9000
JANUS_OSS_BUCKET=private
JANUS_OSS_ACCESS_KEY=
JANUS_OSS_SECRET_KEY=

# Reversible encryption key(s) for upstream vendor keys (channel_key.api_key_encrypted).
# Fernet symmetric key: 32-byte url-safe base64. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Comma-separate multiple keys for rotation (first encrypts, all decrypt). Only the
# LLM gateway needs this at Router-build time; auth/admin never touch it.
JANUS_CHANNEL_ENCRYPTION_KEYS=
