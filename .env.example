# Secrets and connection strings only. Behavior defaults live in src/config.py.

JANUS_DATABASE_URL=postgresql+asyncpg://janus:janus@localhost:5432/janus
JANUS_REDIS_URL=redis://localhost:6379/0
JANUS_REDIS_ARQ_URL=redis://localhost:6379/1

# Platform JWT signing key for local username/password login (RS256, PKCS8 PEM).
# Only the token issuer (login) needs the private key; replicas verify with the
# derived public key. Escaped newlines (\n) are accepted on a single line.
JANUS_PLATFORM_JWT_PRIVATE_KEY=

# Object storage (MinIO / S3-compatible, private bucket). Endpoint/bucket are
# deployment-specific connection info; access/secret are credentials. Reads use
# short-lived presigned URLs; the DB only stores bucket-relative object keys.
JANUS_OSS_ENDPOINT_URL=http://localhost:9000
JANUS_OSS_BUCKET=private
JANUS_OSS_ACCESS_KEY=
JANUS_OSS_SECRET_KEY=
